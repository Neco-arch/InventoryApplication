<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Urban Pulse</title>
    <link rel="stylesheet" href="/css/mainstyle.css" type="text/css">
</head>

<body>
<div>
    <div class="Top_Part">
        <h1>Category Page</h1>
        <div>
            <button type="submit" id="AddCategory">Add New Category</button>
            <button type="submit" id="Deletecategory">Delete Category</button>
        </div>
    </div>
    <div class="Wrapper">
        <% if (category.length === 0) { %>
            <h1>No category found</h1>
        <% } %>
        <% category.forEach((value, index) => { %>
            <a href="/category/<%= value.category %>">
                <div class="Category_Card">
                    <img src="/images.png">
                    <h2><%= value.category %></h2>
                </div>
            </a>
        <% }) %>
    </div>
</div>

    <script>
        document.querySelector("#AddCategory").addEventListener("click", () => {
            const Category = prompt("Category Name:")

            const response = fetch("/addcategory", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ Category: Category })
            })

            response.then((value) => {
                if (value.ok) {
                    window.location.href = "/"
                }
            })
        })

        document.querySelector("#Deletecategory").addEventListener("click", () => {
            const Category = prompt("Category Name you want to delete :")
            const response = fetch("/deletecategory", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ Category })
            })

            response.then((value) => {
                if (value.ok) {
                    window.location.href = "/"
                }
            })
        })
    </script>
</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Urban Pulse</title>
</head>

<body>
    <div>
        <% if (products.length===0) { %>
            <h2>No Product in category</h2>
            <% } %>
                <% products.forEach((value, index)=> { %>
                    <div class="Prodcut">
                        <img src="/images.png">
                        <h2>
                            <%= value.itemname %>
                        </h2>
                        <h3>
                            <%= value.description %>
                        </h3>
                        <h3>
                            <%= value.price %>$
                        </h3>
                        <h3>Amount of item : <%= value.quantity%>
                        </h3>
                        <h3>Status : <%= value.status%>
                        </h3>
                        <form method="post" action="/viewproduct">
                            <input type="hidden" name="productId" value="<%= value.id %>">
                            <input type="submit" value="Action">
                        </form>
                    </div>
                    <% }) %>
    </div>
    <a href="/">Back to homepage</a>
</body>

</html>